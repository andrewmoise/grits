{
  "storageSize": 0,
  "storageFreeSize": 0,
  "runAsUser": "%USER%",
  "doLogging": true,
  "modules": [
    {
      "module": "volume",
      "volumeName": "primary"
    },
    {
      "module": "mount",
      "volume": "primary",
      "mountPoint": "mnt"
    },

    {
      "module": "http",
      "thisPort": 443,
      "enableTls": true,
      "readOnly": true,
      "autoCertificate": true,
      "certbotEmail": "%YOUR_EMAIL%"
    },

    {
      "module": "cmdline"
    },

    {
      "module": "auth",
      "coreVhost": "%YOUR_DOMAIN%.com"
    },

    {
      "module": "startup",
      "commands": [
        ["import", "-p", "./client", "//primary/sites/gimbal.%YOUR_DOMAIN%.com/live"]
      ]
    }
  ]
}
