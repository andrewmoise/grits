{
  "storageSize": 0,
  "storageFreeSize": 0,
  "runAsUser": "%USER%",
  "modules": [
    {
      "module": "volume",
      "volumeName": "root"
    },
    {
      "module": "mount",
      "volume": "root",
      "mountPoint": "mnt"
    },

    {
      "module": "http",
      "thisPort": 443,
      "enableTls": true,
      "readOnly": true,
      "autoCertificate": true,
      "certbotEmail": "%EMAIL%"
    },

    {
      "module": "cmdline"
    },

    {
      "module": "auth",
      "coreVhost": "https://%YOUR_SERVER%"
    }
  ]
}
