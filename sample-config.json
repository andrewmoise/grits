{
  "storageSize": 0,
  "storageFreeSize": 0,
  "runAsUser": "%USER%",
  "doLogging": true,
  "modules": [
    {
      "module": "volume",
      "volumeName": "primary"
    },
    {
      "module": "mount",
      "volume": "primary",
      "mountPoint": "mnt"
    },

    {
      "module": "http",
      "thisPort": 443,
      "enableTls": true,
      "readOnly": false,
      "autoCertificate": true,
      "certbotEmail": "%YOUR_EMAIL%"
    },

    {
      "module": "cmdline"
    },

    {
      "module": "auth",
      "coreVhost": "%YOUR_DOMAIN%.com"
    },

    {
      "module": "rateLimit",
      "uploadBytes":     {"max": 10485760, "duration": "1h"},
      "accountCreation": {"max": 3,        "duration": "1h"},
      "siteCreation":    {"max": 5,        "duration": "1h"}
    },

    {
      "module": "startup",
      "commands": [
        ["import", "-p", "./client", "//primary/sites/gimbal.%YOUR_DOMAIN%.com/live"]
      ]
    }
  ]
}
