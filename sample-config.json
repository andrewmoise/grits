{
  "storageSize": 0,
  "storageFreeSize": 0,
  "runAsUser": "%USER%",
  "modules": [
    {
      "type": "volume",
      "volumeName": "root"
    },
    {
      "type": "mount",
      "volume": "root",
      "mountPoint": "mnt"
    },

    {
      "type": "http",
      "thisPort": 443,
      "enableTls": true,
      "readOnly": true,
      "autoCertificate": true,
      "certbotEmail": "%EMAIL%"
    }
  ]
}
