{
  "storageSize": 0,
  "storageFreeSize": 0,
  "runAsUser": "%USER%",
  "modules": [
    {
      "type": "volume",
      "volumeName": "client"
    },
    {
      "type": "mount",
      "volume": "client",
      "mountPoint": "volumes/client"
    },

    {
      "type": "volume",
      "volumeName": "home"
    },
    {
      "type": "mount",
      "volume": "home",
      "mountPoint": "volumes/home"   
    },

    {
      "type": "volume",
      "volumeName": "sites"
    },
    {
      "type": "mount",
      "volume": "sites",
      "mountPoint": "volumes/sites"
    },

    {
      "type": "volume",
      "volumeName": "sys"
    },
    {
      "type": "mount",
      "volume": "sys",
      "mountPoint": "volumes/sys"
    },

    {
      "type": "http",
      "thisPort": 443,
      "enableTls": true,
      "readOnly": true,
      "autoCertificate": true,
      "certbotEmail": "%EMAIL%"
    },

    {
      "type": "startup",
      "commands": [
        ["import", "./client", "//client"]
      ]
    }
  ]
}
